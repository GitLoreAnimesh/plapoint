# Server
NODE_ENV=development
PORT=5000

# Public URL of this server (used for SSLCommerz callback URLs)
# In production set this to your actual domain e.g. https://api.playpoint.com
API_BASE_URL=http://localhost:5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/playpoint

# JWT — access token (short-lived, stored in memory on client)
JWT_ACCESS_SECRET=your_access_secret_here
JWT_ACCESS_EXPIRE=15m

# JWT — refresh token (long-lived, HttpOnly cookie)
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRE=7d

# Client URL (for CORS and SSLCommerz redirect URLs)
CLIENT_URL=http://localhost:3000

# SSLCommerz Payment Gateway
# Register at https://developer.sslcommerz.com for sandbox credentials
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
# Set to true only in production with live credentials
SSLCOMMERZ_IS_LIVE=false
